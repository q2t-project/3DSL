{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://q2t-project.github.io/3DSL/schemas/3DSS.schema.json",
  "title": "3D Structural Schema",
  "type": "object",
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "version": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "version", "date"]
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "pos": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "label": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "fontSize": { "type": "number" },
              "fontFamily": { "type": "string" },
              "color": { "type": "string" },
              "background": { "type": ["string", "null"] },
              "opacity": { "type": "number" },
              "plane": {
                "type": "string",
                "enum": ["xy", "yz", "zx"],
                "default": "zx"
              }
            },
            "required": ["text"]
          }
        },
        "required": ["id", "pos", "label"]
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "color": { "type": "string" },
          "opacity": { "type": "number" },
          "label": { "$ref": "#/properties/nodes/items/properties/label" }
        },
        "required": ["source", "target"]
      }
    },
    "aux": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["grid", "axis"] }
        },
        "required": ["type"]
      }
    }
  },
  "required": ["meta", "nodes", "edges", "aux"]
}
