{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://3dsl.dev/schema/scene.json",
  "title": "Scene",
  "type": "object",
  "required": ["id", "nodes"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "\\S"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "https://3dsl.dev/schema/node.json"
      }
    },
    "metadata": {
      "$ref": "https://3dsl.dev/schema/metadata.json"
    }
  }
}
